{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "openclaw/plugin-sdk/plugin-entry": ["./stub/openclaw-plugin-entry.ts"]
    }
  },
  "include": ["./**/*.ts", "./stub/**/*.ts"],
  // Imports collector sources outside rootDir; still run via `pnpm test` / tsx.
  "exclude": ["./ingest-chain-smoke.test.ts"]
}
